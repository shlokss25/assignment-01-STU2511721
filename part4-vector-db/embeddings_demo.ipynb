!pip install sentence-transformers seaborn

# Import libraries
from sentence_transformers import SentenceTransformer
from sklearn.metrics.pairwise import cosine_similarity
import seaborn as sns
import matplotlib.pyplot as plt


# ======================================================
# Step 1: Define Sentences (10 sentences, 3 topics)
# ======================================================

sentences = [
    # Cricket
    "The batsman scored a century in the match",
    "The bowler delivered a fast yorker",
    "The team won the match by six wickets",

    # Cooking
    "The chef prepared a delicious pasta dish",
    "Boiling water is essential for cooking rice",
    "Spices enhance the flavor of food",

    # Cybersecurity
    "Strong passwords help protect user accounts",
    "Encryption secures sensitive data",
    "Phishing attacks trick users into revealing information",
    "Firewalls prevent unauthorized access to networks"
]


# ======================================================
# Step 2: Load Model & Generate Embeddings
# ======================================================

model = SentenceTransformer('all-MiniLM-L6-v2')
embeddings = model.encode(sentences)


# ======================================================
# Step 3: Compute Cosine Similarity Matrix
# ======================================================

similarity_matrix = cosine_similarity(embeddings)


# ======================================================
# Step 4: Visualize Heatmap
# ======================================================

plt.figure(figsize=(10, 8))
sns.heatmap(similarity_matrix, annot=True, cmap="coolwarm")
plt.title("10x10 Cosine Similarity Matrix")
plt.show()


# ======================================================
# Step 5: Query Similarity Search
# ======================================================

query = "The bowler took three wickets in one over"

query_embedding = model.encode([query])

similarities = cosine_similarity(query_embedding, embeddings)[0]

# Get Top 2 similar sentences
top_indices = similarities.argsort()[-2:][::-1]


# ======================================================
# Step 6: Display Results
# ======================================================

print("Query:", query)
print("\nTop 2 Most Similar Sentences:\n")

for i in top_indices:
    print(f"Sentence: {sentences[i]}")
    print(f"Similarity Score: {similarities[i]:.4f}")
    print()